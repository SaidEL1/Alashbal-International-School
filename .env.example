# =============================================================================
# Alashbal International School — Environment Variables
# Copy to .env.local for local development
# =============================================================================

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# Database (Neon PostgreSQL — or Docker: pnpm docker:up)
DATABASE_URL=postgresql://ais:ais_dev_password@localhost:5432/alashbal

# Auth (NextAuth v5 — Sprint 6)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Email (Resend — Sprint 4)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@mail.aisdoha.net

# Media (Cloudinary — Sprint 3+)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# reCAPTCHA (Sprint 4)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Redis / Upstash (Sprint 4)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI Chat (Sprint 7)
AI_API_KEY=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# WhatsApp (Sprint 3)
NEXT_PUBLIC_WHATSAPP_NUMBER=97444507882

# Seed (local only)
SEED_ADMIN_EMAIL=admin@aisdoha.net
